# -------------------------------------------------------
# API Test Environment — copy sang .env rồi điền ID thực
# -------------------------------------------------------

# URL của booking-service (mặc định localhost Docker)
BOOKING_SERVICE_URL=http://localhost:8088/api/v1

# Profile ID của người dùng (buyer) dùng để gửi request
TEST_PROFILE_ID=test-profile-001

# Profile ID của người bán (seller) sở hữu listing variant
TEST_SELLER_PROFILE_ID=test-seller-001

# Customer ID hợp lệ trong DB (từ customer-service)
TEST_CUSTOMER_ID=test-customer-001

# Listing Variant ID có inventory loại RENT
TEST_LISTING_VARIANT_ID=test-variant-001

# Facility ID thuộc seller ở trên
TEST_FACILITY_ID=test-facility-001
