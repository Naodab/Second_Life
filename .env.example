# Copy to .env for local/docker use. Do not commit .env.

# --- MySQL (Aiven hoặc docker-compose.prod mysql) ---
MYSQL_URL=jdbc:mysql://HOST:PORT/defaultdb?ssl-mode=REQUIRED
MYSQL_USERNAME=
MYSQL_PASSWORD=

# --- OpenSearch (product-service search, Aiven hostname thường bắt đầu bằng os-) ---
OPENSEARCH_URIS=https://os-XXXXXXXX.aivencloud.com:PORT
OPENSEARCH_USERNAME=avnadmin
OPENSEARCH_PASSWORD=

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# --- Auth / OAuth ---
JWT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost

# --- Service URLs (docker compose in-network) ---
GATEWAY_URL=http://localhost:8080
AUTH_SERVICE_URL=http://auth-service:8081/api/v1
PROFILE_SERVICE_URL=http://profile-service:8082/api/v1
LOCATION_SERVICE_URL=http://location-service:8085/api/v1
PRODUCT_SERVICE_URL=http://product-service:8086/api/v1
INVENTORY_SERVICE_URL=http://inventory-service:8087/api/v1

# --- Optional ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
