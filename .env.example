# Copy to .env for local/docker use. Do not commit .env.

# --- MySQL (Aiven hoặc docker-compose.prod mysql) ---
MYSQL_URL=jdbc:mysql://HOST:PORT/defaultdb?ssl-mode=REQUIRED
MYSQL_USERNAME=
MYSQL_PASSWORD=

# --- OpenSearch (product-service search, Aiven hostname thường bắt đầu bằng os-) ---
OPENSEARCH_URIS=https://os-XXXXXXXX.aivencloud.com:PORT
OPENSEARCH_USERNAME=avnadmin
OPENSEARCH_PASSWORD=

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# --- MongoDB (mail-service notifications; cluster bên ngoài Docker) ---
# Bắt buộc khi chạy mail-service. Ví dụ Atlas:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/secondlife?retryWrites=true&w=majority
# Ví dụ self-hosted có auth:
# MONGODB_URI=mongodb://USER:PASSWORD@HOST:27017/secondlife?authSource=admin
MONGODB_URI=
# Tên database (dùng khi URI không có path, ví dụ Atlas chỉ có ?appName=...)
MONGODB_DATABASE=secondlife

# --- Auth / OAuth ---
JWT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Frontend callback sau OAuth (Spring whitelist; Google Console KHÔNG cần URI này)
APP_OAUTH2_FALLBACK_REDIRECT_URI=http://localhost:5173/oauth2/callback/google
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost

# --- Public URLs (email verify link + redirect sau khi bấm link) ---
# GATEWAY_URL = cổng Traefik/API mà trình duyệt gọi được (dev docker: cổng 80)
GATEWAY_URL=http://localhost
AUTH_SERVICE_PUBLIC_BASE_URL=http://localhost/api/v1

# --- Service URLs (docker compose in-network) ---
AUTH_SERVICE_URL=http://auth-service:8081/api/v1
PROFILE_SERVICE_URL=http://profile-service:8082/api/v1
LOCATION_SERVICE_URL=http://location-service:8085/api/v1
PRODUCT_SERVICE_URL=http://product-service:8086/api/v1
INVENTORY_SERVICE_URL=http://inventory-service:8087/api/v1
AI_SERVICE_URL=http://ai-service:8090

# --- Optional ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
