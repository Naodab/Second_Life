# Local Vite dev/preview — copy to .env
PORT=5173
BASE_PATH=/

# API base — dev: Traefik trên cổng 80 → http://localhost (không dùng :8080 trừ khi gateway thật sự ở 8080)
VITE_BACKEND_URL=http://localhost
# OAuth callback luôn về Vite (kể cả khi mở app qua http://localhost qua Traefik)
VITE_FRONTEND_URL=http://localhost:5173
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
VITE_CLOUDINARY_MAX_VIDEO_BYTES=
