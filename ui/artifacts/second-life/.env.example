# Vite dev / preview — copied to .env for local runs (see vite.config.ts loadEnv)
PORT=5173
# Public URL path prefix; use / for root
BASE_PATH=/

# API base: Traefik (all routes) http://localhost — or direct authservice http://localhost:8081 (OAuth only)
VITE_BACKEND_URL=http://localhost
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
