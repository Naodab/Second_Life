# Vite dev / preview — copied to .env for local runs (see vite.config.ts loadEnv)
PORT=5173
# Public URL path prefix; use / for root
BASE_PATH=/

# API base: Traefik gateway (tất cả route /api/v1/*)
VITE_BACKEND_URL=http://localhost
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
VITE_CLOUDINARY_MAX_VIDEO_BYTES=
