# Production environment — copy to .env on the server (do not commit .env).

# --- Spring (all microservices) ---
SPRING_PROFILES_ACTIVE=prod
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# --- MySQL managed (Aiven / RDS / VPS riêng — không chạy trong docker-compose prod) ---
MYSQL_URL=jdbc:mysql://HOST:PORT/defaultdb?ssl-mode=REQUIRED
MYSQL_USERNAME=avnadmin
MYSQL_PASSWORD=

# Location DB (cùng server hoặc URL riêng)
LOCATION_MYSQL_URL=jdbc:mysql://HOST:PORT/second_life_location?ssl-mode=REQUIRED

# Inventory — điền cùng giá trị MYSQL_URL / USERNAME / PASSWORD ở trên
# (Docker Compose không expand biến trong .env, không dùng ${MYSQL_URL})
INVENTORY_MYSQL_URL=jdbc:mysql://HOST:PORT/defaultdb?ssl-mode=REQUIRED
INVENTORY_MYSQL_USERNAME=avnadmin
INVENTORY_MYSQL_PASSWORD=

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Kafka / OpenSearch ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
OPENSEARCH_URIS=https://os-XXXXXXXX.aivencloud.com:PORT
OPENSEARCH_USERNAME=avnadmin
OPENSEARCH_PASSWORD=

# --- Domain production ---
PUBLIC_DOMAIN=secondlifeonline.xyz
ACME_EMAIL=admin@secondlifeonline.xyz

# --- Traefik dashboard (prod) ---
# htpasswd -nb admin_secondlife 'your-strong-password' > traefik/dashboard.htpasswd
# Không dùng htpasswd -B (-nbB): hash $2y$ trên macOS Traefik không chấp nhận.
# File chỉ 1 dòng user:hash, không comment. URL: https://secondlifeonline.xyz/dashboard/
# Mẫu dashboard.htpasswd.example: admin_secondlife / changeme

# --- URLs công khai ---
FRONTEND_URL=https://secondlifeonline.xyz
GATEWAY_URL=https://secondlifeonline.xyz
AUTH_SERVICE_PUBLIC_BASE_URL=https://secondlifeonline.xyz/api/v1
CORS_ALLOWED_ORIGINS=https://secondlifeonline.xyz,https://www.secondlifeonline.xyz

# OAuth Google — xem DEPLOY-PRODUCTION.md (Google redirect = backend /login/oauth2/code/google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APP_OAUTH2_FALLBACK_REDIRECT_URI=https://secondlifeonline.xyz/oauth2/callback/google
# Tuỳ chọn thêm (phẩy): https://www.secondlifeonline.xyz/oauth2/callback/google
APP_OAUTH2_AUTHORIZED_REDIRECT_URIS=

# --- JWT & admin ---
JWT_SECRET=change-me-min-32-chars-random
ACCOUNT_ADMIN_EMAIL=
ACCOUNT_ADMIN_PASSWORD=

# --- Inter-service (Docker DNS) ---
PROFILE_SERVICE_URL=http://profile-service:8082/api/v1
LOCATION_SERVICE_URL=http://location-service:8085/api/v1
INVENTORY_SERVICE_URL=http://inventory-service:8087/api/v1
PRODUCT_SERVICE_URL=http://product-service:8086/api/v1

# --- Mail (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM=noreply@secondlifeonline.xyz
MAIL_FROM_NAME=Second Life

# --- AI (product service) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash-8b

# --- UI build (docker service second-life-ui) ---
# Để trống = gọi API cùng origin qua Traefik (khuyến nghị khi UI+API cùng domain)
VITE_BACKEND_URL=
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
VITE_CLOUDINARY_MAX_VIDEO_BYTES=52428800
