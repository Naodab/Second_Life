# Production profile — copy to application-prod.yml or rely on Docker build (see Dockerfile).

server:
  error:
    include-message: never
    include-binding-errors: never
    include-stacktrace: never

# OpenSearch: OPENSEARCH_URIS, OPENSEARCH_USERNAME, OPENSEARCH_PASSWORD trong .env / biến môi trường

spring:
  jpa:
    hibernate:
      ddl-auto: validate
    show-sql: false

external:
  location-service:
    url: ${LOCATION_SERVICE_URL:http://location-service:8085/api/v1}
  inventory-service:
    url: ${INVENTORY_SERVICE_URL:http://inventory-service:8087/api/v1}
  cors_allowed_origins: ${CORS_ALLOWED_ORIGINS}

gemini:
  api-key: ${GEMINI_API_KEY:}
  model: ${GEMINI_MODEL:gemini-1.5-flash-8b}

logging:
  level:
    root: WARN
    "[com.naodab.productservice]": INFO
    "[org.springframework.data.elasticsearch]": WARN
    "[org.opensearch.client]": WARN

springdoc:
  api-docs:
    enabled: false
  swagger-ui:
    enabled: false
