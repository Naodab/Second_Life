# Copy to application-dev.yml and adjust (application-dev.yml is gitignored).

server:
  error:
    include-message: always
    include-binding-errors: always

spring:
  datasource:
    url: ${MYSQL_URL:jdbc:mysql://127.0.0.1:3306/second_life?ssl-mode=REQUIRED}
    username: ${MYSQL_USERNAME:dev}
    password: ${MYSQL_PASSWORD:changeme}
  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true
    properties:
      hibernate:
        "[format_sql]": true
  jackson:
    serialization:
      "[indent_output]": true

external:
  location-service:
    url: ${LOCATION_SERVICE_URL:http://localhost:8085/api/v1}
  inventory-service:
    url: ${INVENTORY_SERVICE_URL:http://localhost:8087/api/v1}
  ai-service:
    url: ${AI_SERVICE_URL:http://localhost:8090}
  cors_allowed_origins: ${CORS_ALLOWED_ORIGINS:http://localhost:5173,http://localhost}

# Lấy key tại: https://aistudio.google.com/apikey
gemini:
  api-key: ${GEMINI_API_KEY:AIza-your-gemini-api-key-here}
  model: ${GEMINI_MODEL:gemini-1.5-flash-8b}

logging:
  level:
    root: INFO
    "[com.naodab.productservice]": DEBUG
    "[org.springframework.data.elasticsearch.client.WIRE]": TRACE
    "[org.opensearch.client]": DEBUG
