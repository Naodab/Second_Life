# Production profile — copy to application-prod.yml before build/deploy (file is gitignored).
# Docker images bake this in automatically (see authservice/Dockerfile).
# Secrets: set via .env / environment (JWT_SECRET, GOOGLE_*, MYSQL_*, …).

server:
  error:
    include-message: never
    include-binding-errors: never
    include-stacktrace: never

spring:
  jpa:
    hibernate:
      ddl-auto: validate
    show-sql: false

app:
  oauth2:
    authorized-redirect-uris:
      - ${APP_OAUTH2_FALLBACK_REDIRECT_URI}

external:
  frontend_url: ${FRONTEND_URL}
  gateway_url: ${GATEWAY_URL}
  auth_service_public_base_url: ${AUTH_SERVICE_PUBLIC_BASE_URL:${GATEWAY_URL}/api/v1}
  cors_allowed_origins: ${CORS_ALLOWED_ORIGINS}

profile-service:
  url: ${PROFILE_SERVICE_URL}

logging:
  level:
    root: WARN
    "[com.naodab.authservice]": INFO
    "[org.springframework.security]": WARN

springdoc:
  api-docs:
    enabled: true
  swagger-ui:
    enabled: false
