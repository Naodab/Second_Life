# Production profile — copy to application-prod.yml or rely on Docker build (see Dockerfile).

server:
  error:
    include-message: never
    include-binding-errors: never
    include-stacktrace: never

app:
  mail:
    base-url: ${GATEWAY_URL}
  frontend:
    url: ${FRONTEND_URL}

external:
  cors_allowed_origins: ${CORS_ALLOWED_ORIGINS}

logging:
  level:
    root: WARN
    "[com.naodab.mailservice]": INFO
    "[org.springframework.kafka]": WARN

springdoc:
  api-docs:
    enabled: false
  swagger-ui:
    enabled: false
